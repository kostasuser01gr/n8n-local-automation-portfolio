# n8n/PostgreSQL local example values.
# Copy to .env only in your own private environment and replace all placeholders.

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=replace_me
POSTGRES_USER=replace_me
POSTGRES_PASSWORD=replace_me

N8N_POSTGRES_CREDENTIAL_NAME=Local n8n Postgres
JOB_TRACKER_IMPORT_PATH=/files/job-tracker/jobs-import-example.json
